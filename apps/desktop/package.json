{
  "name": "@stockdesk/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "build:dir": "electron-vite build && electron-builder --dir",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.73.3",
    "@fluentui/react-icons": "^2.0.321",
    "@stockdesk/analysis-core": "workspace:*",
    "@stockdesk/db": "workspace:*",
    "@stockdesk/shared": "workspace:*",
    "@tanstack/react-query": "^5.87.4",
    "better-sqlite3": "^11.10.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "lightweight-charts": "^5.0.8",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "zod": "^4.1.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "vite": "^7.1.3"
  },
  "build": {
    "appId": "com.stockdesk.desktop",
    "productName": "StockDesk",
    "asarUnpack": [
      "**/*.node"
    ],
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "../data-service/packaging",
        "to": "python-service",
        "filter": [
          "**/*"
        ]
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
